# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# --- LLM provider --------------------------------------------------------
# Which vendor backs every model call: gemini (default) | anthropic | openai.
# Switching only needs this line + that provider's API key below; per-role model
# ids default sensibly per provider and can be pinned with MODEL_* further down.
LLM_PROVIDER=gemini

# --- Google Gemini (default provider) ------------------------------------
# Required in production when LLM_PROVIDER=gemini. Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# --- Anthropic / Claude (LLM_PROVIDER=anthropic) -------------------------
# Required in production when LLM_PROVIDER=anthropic. Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Max output tokens per call / per streamed call (defaults shown).
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_STREAM_MAX_TOKENS=16000

# --- OpenAI (LLM_PROVIDER=openai) ----------------------------------------
# Required in production when LLM_PROVIDER=openai. Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MAX_TOKENS=8192

# development | production | testing. Production enforces required secrets
# and secure cookies.
APP_ENV=development

# Recommended (REQUIRED in production): stable secret for session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Optional: legacy master password gate for the whole UI.
PASSWORD=

# Optional: port to bind (hosts like Render set this automatically).
PORT=5000

# --- Accounts & persistence (Tier 7) -------------------------------------
# Enable email/password accounts (registration UI appears in the app).
ACCOUNTS_ENABLED=true
# Force login for all API use (disables the anonymous sandbox mode).
REQUIRE_LOGIN=false
# Require new accounts to confirm their email (a link is emailed; needs SMTP_*
# below, otherwise the link is logged for dev). Off by default.
REQUIRE_EMAIL_VERIFICATION=false
# SQLAlchemy database URL. Empty -> SQLite file under instance/.
# Production example: postgresql+psycopg://user:pass@host:5432/statlee
DATABASE_URL=

# Storage backend for uploads: local | s3
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=statlee
# Root directory for uploaded/working files. Empty -> a fresh temp dir per run.
UPLOAD_ROOT=

# --- Model routing & cost (3.4) --------------------------------------------
# Override any model id without touching code. Leave commented to use the
# per-provider defaults; set one to pin a specific model. MODEL_PRO is the
# default code-generation model; MODEL_PRO_MAX is the bigger model the in-app
# "Pro mode" toggle switches code generation to on demand.
#   gemini   : MODEL_PRO=gemini-3.5-flash MODEL_PRO_MAX=gemini-3.1-pro-preview
#              MODEL_FLASH=gemini-3.1-flash-lite MODEL_FLASH_LITE=gemini-3.1-flash-lite
#   anthropic: MODEL_PRO=claude-opus-4-8 MODEL_PRO_MAX=claude-opus-4-8
#              MODEL_FLASH=claude-sonnet-4-6 MODEL_FLASH_LITE=claude-haiku-4-5
#   openai   : MODEL_PRO=gpt-5.4 MODEL_PRO_MAX=gpt-5.5
#              MODEL_FLASH=gpt-5.4-mini MODEL_FLASH_LITE=gpt-5.4-nano
# MODEL_PRO=
# MODEL_PRO_MAX=
# MODEL_FLASH=
# MODEL_FLASH_LITE=
# Which tier answers Converse questions: pro | flash | lite
CONVERSE_ROLE=flash
# Which tier runs conversational data cleaning ("delete column 2", "filter X").
# Defaults to the cheapest tier (lite) since these are short, structured edits.
WRANGLE_ROLE=lite
# Column count above which the analysis pipeline runs a feature-selection pass
# (picks the minimal relevant columns) before drafting code on wide datasets.
FEATURE_SELECTION_THRESHOLD=15

# --- Billing / cost guardrails (workstream E) --------------------------------
# >>> MONEY SAFETY <<< If you ever deploy with a real GEMINI_API_KEY, every LLM
# call costs YOU money. To let people trial the app without risking your wallet:
#   1) Keep BILLING_ENABLED=false (free trial) but ALWAYS set a low
#      MONTHLY_PRIORITY_CALL_CEILING so total priority spend is capped.
#   2) Keep RATE_LIMIT_* on (below) with a shared store so caps actually hold.
#   3) Use a Gemini key with a hard spend limit set in Google AI Studio billing.
# The app will warn at startup if BILLING_ENABLED=true with no ceiling set.
#
# Turn on credit debiting in billing.check_and_debit (off = always authorize).
BILLING_ENABLED=false
# Hard ceiling on priority (high-tier) requests per calendar month on the
# server's own key (0 disables = UNCAPPED, not recommended once live). A coarse,
# per-process guardrail: start low (e.g. 200) and raise it as you trust demand.
MONTHLY_PRIORITY_CALL_CEILING=200
# Free credits granted to a logged-in free-plan user, topped up lazily on their
# first request each calendar month (0 = off; every free user then starts at 0
# credits and needs a `flask grant-credits <email> <n>` grant). Only meaningful
# when BILLING_ENABLED=true.
MONTHLY_FREE_CREDITS=0

# --- Execution sandbox (Tier 0) ----------------------------------------------
# subprocess (default) | docker (sibling containers from runner.Dockerfile)
SANDBOX_MODE=subprocess
RUNNER_IMAGE=statlee-runner
# Parent dir for per-run sandbox work dirs. Empty -> system temp dir.
# REQUIRED for SANDBOX_MODE=docker when the app ITSELF runs in a container with
# the host docker socket mounted: `docker run -v` is resolved by the host
# daemon against the host filesystem, so set this to a path bind-mounted at the
# SAME absolute path into the app container (see docker-compose.yml). Example:
# SANDBOX_WORK_ROOT=/srv/statlee-runs
SANDBOX_WORK_ROOT=
EXEC_TIMEOUT=60
EXEC_MEMORY_MB=2048
# Max bytes of stdout+stderr captured from a sandbox run before truncation.
EXEC_OUTPUT_LIMIT=262144

# --- Limits ---------------------------------------------------------------------
MAX_UPLOAD_MB=16
PDF_MAX_PAGES=50
DATA_PAGE_ROW_CAP=500000
# Per-identity storage caps (disk-fill abuse protection; 0 disables either cap).
# Version artifacts do not count toward the dataset count, only real uploads do.
MAX_DATASETS_PER_IDENTITY=10
MAX_BYTES_PER_IDENTITY=209715200
# How long an anonymous session's uploaded files live before TTL cleanup (seconds).
FILE_TTL_SECONDS=7200
RATE_LIMIT_ENABLED=true
# Applies to any route with no explicit per-route limit below.
RATE_LIMIT_DEFAULT=120 per minute
RATE_LIMIT_RUN=10 per minute
RATE_LIMIT_CHAT=20 per minute
# Guards the token-consuming email-verification endpoint against brute force.
RATE_LIMIT_VERIFY=5 per minute
# Guards /login and /register against credential stuffing and mass signups.
RATE_LIMIT_AUTH=10 per minute
# Backing store for rate-limit counters. Default memory:// is PER-WORKER and
# resets on restart — with more than one gunicorn worker (WEB_CONCURRENCY>1) it
# does NOT enforce a shared limit, weakening bill-abuse protection. Use a shared
# store in production or pin WEB_CONCURRENCY=1. REDIS_URL is used as a fallback.
RATELIMIT_STORAGE_URI=
REDIS_URL=
# Gunicorn worker count in the container (see Dockerfile CMD).
WEB_CONCURRENCY=
# Trusted reverse-proxy hops in front of the app (enables ProxyFix so rate
# limiting sees the real client IP from X-Forwarded-For). Defaults to 1 in
# production (Render fronts the app with one proxy); keep 0 if exposed directly.
TRUST_PROXY_HOPS=

# --- Issue-report email (6.3, optional) -------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ISSUE_REPORT_TO=
