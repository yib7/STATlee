# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Required: Your Google Gemini API key.
GEMINI_API_KEY=your_api_key_here

# Recommended: A stable secret used to sign session cookies.
# If unset, a random key is generated on each start — logins reset on restart
# and break across multiple workers. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Optional: Set a master password to lock the web interface.
# IMPORTANT: When deployed publicly, leaving this unset lets anyone run
# arbitrary code on the server via the /run endpoint. Always set it in prod.
PASSWORD=

# Optional: Port to bind to (defaults to 5000 locally; hosts like Render set this).
PORT=5000
