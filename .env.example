# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# --- LLM (Google Gemini) ------------------------------------------------
# Required in production. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# development | production | testing. Production enforces required secrets
# and secure cookies.
APP_ENV=development

# Recommended (REQUIRED in production): stable secret for session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Optional: legacy master password gate for the whole UI.
PASSWORD=

# Optional: port to bind (hosts like Render set this automatically).
PORT=5000

# --- Accounts & persistence (Tier 7) -------------------------------------
# Enable email/password accounts (registration UI appears in the app).
ACCOUNTS_ENABLED=true
# Force login for all API use (disables the anonymous sandbox mode).
REQUIRE_LOGIN=false
# Require new accounts to confirm their email (a link is emailed; needs SMTP_*
# below, otherwise the link is logged for dev). Off by default.
REQUIRE_EMAIL_VERIFICATION=false
# SQLAlchemy database URL. Empty -> SQLite file under instance/.
# Production example: postgresql+psycopg://user:pass@host:5432/statlee
DATABASE_URL=

# Storage backend for uploads: local | s3
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=statlee

# --- Model routing & cost (3.4) --------------------------------------------
# Override any model id without touching code. Leave commented to use the
# Gemini defaults shown below; set one to pin a specific model.
# MODEL_PRO=gemini-3.1-pro-preview
# MODEL_FLASH=gemini-3-flash-preview
# MODEL_FLASH_LITE=gemini-3.1-flash-lite-preview
# Which tier answers Converse questions: pro | flash | lite
CONVERSE_ROLE=flash

# --- Billing / cost guardrails (workstream E) --------------------------------
# Turn on credit debiting in billing.check_and_debit (off = always authorize).
BILLING_ENABLED=false
# Hard ceiling on priority (high-tier) requests per calendar month on the
# server's own key (0 disables). A coarse, per-process guardrail.
MONTHLY_PRIORITY_CALL_CEILING=0

# --- Execution sandbox (Tier 0) ----------------------------------------------
# subprocess (default) | docker (sibling containers from runner.Dockerfile)
SANDBOX_MODE=subprocess
RUNNER_IMAGE=statlee-runner
EXEC_TIMEOUT=60
EXEC_MEMORY_MB=2048

# --- Limits ---------------------------------------------------------------------
MAX_UPLOAD_MB=16
PDF_MAX_PAGES=50
DATA_PAGE_ROW_CAP=500000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RUN=10 per minute
RATE_LIMIT_CHAT=20 per minute
# Backing store for rate-limit counters. Default memory:// is PER-WORKER and
# resets on restart — with more than one gunicorn worker (WEB_CONCURRENCY>1) it
# does NOT enforce a shared limit, weakening bill-abuse protection. Use a shared
# store in production or pin WEB_CONCURRENCY=1. REDIS_URL is used as a fallback.
RATELIMIT_STORAGE_URI=
REDIS_URL=
# Gunicorn worker count in the container (see Dockerfile CMD).
WEB_CONCURRENCY=
# Trusted reverse-proxy hops in front of the app (enables ProxyFix so rate
# limiting sees the real client IP from X-Forwarded-For). Defaults to 1 in
# production (Render fronts the app with one proxy); keep 0 if exposed directly.
TRUST_PROXY_HOPS=

# --- Issue-report email (6.3, optional) -------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ISSUE_REPORT_TO=
